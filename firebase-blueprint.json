{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user." },
        "displayName": { "type": "string", "description": "The display name of the user." },
        "email": { "type": "string", "format": "email", "description": "The email address of the user." },
        "photoURL": { "type": "string", "description": "The URL of the user's profile photo." },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "The role of the user." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The time the user was created." }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile information."
    }
  }
}
